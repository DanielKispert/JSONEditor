+                JsonEditorEditorWindow window = (JsonEditorEditorWindow) windowNode;
+                if (path.equals(window.getSelectedPath()))
+                {
+                    window.requestFocus();
+                    return true;
+                }
+                if (window.getOpenChildPaths().contains(path))
+                {
+                    window.requestFocus();
+                    window.focusArrayItem(path);
